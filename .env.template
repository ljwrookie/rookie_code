# Copy to `.env` and fill in real values.
# Keep this file committed; keep `.env` private.

#####################################################################
# LLM Provider Keys (choose one provider: Anthropic or OpenAI/Ark)
#####################################################################

# If set, the CLI will default to provider=anthropic.
ANTHROPIC_API_KEY=sk-ant-test_0123456789abcdefghijklmnopqrstuvwxyz

# If set (or ARK_API_KEY is set), the CLI can use provider=openai.
OPENAI_API_KEY=sk-test_0123456789abcdefghijklmnopqrstuvwxyz

# ByteDance Ark (OpenAI-compatible). If both ARK_API_KEY and OPENAI_API_KEY exist,
# ARK_API_KEY takes precedence for provider=openai.
ARK_API_KEY=ark_test_01234567-89ab-cdef-0123-456789abcdef

#####################################################################
# Custom Models (optional)
#####################################################################

# Map a model name to a provider and/or baseURL (no secrets here).
# The CLI selects apiKey from ARK_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY.
#
# NOTE: use single quotes to avoid escaping JSON quotes in dotenv.
CUSTOM_MODELS='[
  {
    "name": "gpt-5.4",
    "provider": "openai",
    "baseURL": "https://ark-cn-beijing.example.com/api/v3"
  },
  {
    "name": "claude-sonnet-4-20250514",
    "provider": "anthropic"
  }
]'

#####################################################################
# Agent Runtime Tweaks (optional)
#####################################################################

# Maximum recursion depth for nested agent calls (positive integer).
ROOKIE_MAX_AGENT_DEPTH=3

# Maximum number of parallel agents for multi-agent tools (positive integer).
ROOKIE_MAX_PARALLEL_AGENTS=5

#####################################################################
# Skills Directories (optional)
#####################################################################

# Comma-separated list of directories to load skills from.
# Default: `<cwd>/skills`
ROOKIE_SKILLS_DIRS=./skills,./my-skills

#####################################################################
# Editor Context (optional)
#####################################################################

# Where to read editor context JSON from (absolute path preferred; relative is resolved against cwd).
ROOKIE_EDITOR_CONTEXT_PATH=.rookie-code/editor-context.json

# Inline JSON string alternative to ROOKIE_EDITOR_CONTEXT_PATH.
# If both are set, inline wins.
ROOKIE_EDITOR_CONTEXT='{"activeFile":"/path/to/repo/src/index.ts","selections":[{"startLine":12,"endLine":34}]}'
